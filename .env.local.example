## Contact form email delivery via Resend
## Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

## Optional: override the outbound sender.
## In production this should be a verified domain (e.g. noreply@relicsol.com).
## In dev, Resend's onboarding@resend.dev works out of the box.
# RESEND_FROM=Relicsol Website <onboarding@resend.dev>

## Optional: override the notification recipient (defaults to info@relicsol.com).
# CONTACT_TO=info@relicsol.com

## Canonical site URL used by metadata, sitemap, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://www.relicsol.com
